generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Listing {
  id              String   @id @default(cuid())
  title           String?
  description     String?
  tags            String?
  brand           String?
  size            String?
  condition       String?
  notes           String?
  purchasePrice   Float?
  estimatedProfit Float?
  imageUrl        String?
  createdAt       DateTime @default(now())
}
